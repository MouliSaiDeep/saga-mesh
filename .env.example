# Kafka
KAFKA_BROKERS=localhost:9092
# PostgreSQL (order-service)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=orders
# Redis
REDIS_URL=redis://localhost:6379
# Service ports (each service can override PORT)
PORT=8081
HEALTH_PORT=8090
# Note: when running inside Docker Compose, replace localhost with the service names: kafka, postgres, redis
